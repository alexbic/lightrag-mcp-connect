# =====================================================
# lightrag-mcp-connect environment variables
# =====================================================
#
# Copy this file to .env and fill in real values before starting any
# docker compose stack. Variables marked "required" must be set.
#
# Variables are grouped by mode:
#   [COMMON] — required for both simple and gateway modes
#   [SIMPLE] — only for simple mode (direct LightRAG connection)
#   [GATEWAY] — only for gateway mode (workspace routing)
# =====================================================

# -----------------------------------------------------
# [COMMON] Required for both modes
# -----------------------------------------------------

# Public domain used by the remote OAuth connector stacks
# Required for deploy/docker-compose.yml, docker-compose.traefik.yml,
# and docker-compose.full-example.yml
DOMAIN=example.com

# LightRAG API key — authenticate with LightRAG or gateway
# Required: yes
# In simple mode: direct LightRAG key (sees all data)
# In gateway mode: imported as superadmin key (sees all workspaces + admin tools)
LIGHTRAG_API_KEY=your-lightrag-api-key-here

# One-time password for the OAuth login screen shown by mcp-auth-proxy
# Required for remote deploy stacks
MCP_AUTH_PASSWORD=choose-a-long-random-password

# Optional: Inject custom instructions at MCP handshake
# Path to a markdown file with agent instructions. If unset, no instructions are sent.
# See instructions.example.md for format.
LIGHTRAG_MCP_INSTRUCTIONS_FILE=

# Optional: Allow file_path uploads from a trusted local directory
# Must be an absolute path. If unset, file_path uploads are disabled (security).
# Only use this when the MCP server runs on the same machine as your files.
LIGHTRAG_FILE_PATH_ROOT=

# Optional: release/tag/commit for the uvx-installed MCP package inside
# the remote streamable-HTTP wrapper
MCP_GIT_REF=v1.3.0

# -----------------------------------------------------
# [SIMPLE] Direct LightRAG connection (no workspace routing)
# -----------------------------------------------------

# LightRAG instance URL — where MCP talks to LightRAG directly
# Required: yes (default: http://lightrag:9621 if using docker-compose.simple.yml)
LIGHTRAG_BASE_URL=http://lightrag:9621

# LightRAG LLM provider configuration
# Required: yes (for LightRAG to function)
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_BINDING_API_KEY=your-llm-api-key

# LightRAG embedding provider configuration
# Required: yes (for LightRAG to function)
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BINDING_API_KEY=your-embedding-api-key
EMBEDDING_BINDING_HOST=

# -----------------------------------------------------
# [GATEWAY] Workspace routing (multi-tenant mode)
# -----------------------------------------------------

# Gateway URL — where MCP talks to (workspace gateway, not LightRAG directly)
# Required: yes (default: http://lightrag-gateway:9621 if using docker-compose.gateway.yml)
LIGHTRAG_GATEWAY_URL=http://lightrag-gateway:9621

# Gateway admin: there is no separate admin key. LIGHTRAG_API_KEY is
# bootstrapped into the registry with is_admin=true at gateway startup, and
# that same key authorizes every admin operation and unlocks admin MCP tools.
# (No WORKSPACE_ADMIN_KEY env var anymore — admin status lives in the registry.)

# Workspace key hashing pepper — salt for workspace key HMAC-SHA256
# Required: yes (generate a long random string, keep it secret)
# Generate with: openssl rand -base64 48
WORKSPACE_KEY_PEPPER=your-random-pepper-string-min-32-chars

# LightRAG internal server key — gateway uses this to talk to child LightRAG instances
# Required: yes (different from LIGHTRAG_API_KEY, keep secret)
LIGHTRAG_SERVER_KEY=your-internal-server-key-here

# PostgreSQL connection — workspace registry database
# Required: yes (for gateway mode)
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=lightrag

# Optional: existing external docker network name for the Traefik variant
TRAEFIK_NETWORK=

# -----------------------------------------------------
# Workspace gateway tuning (optional, advanced)
# -----------------------------------------------------

# First port for child LightRAG instances (each workspace gets its own port)
# Default: 9700
# WORKSPACE_FIRST_PORT=9700

# Maximum concurrent workspace instances
# Default: 16
# WORKSPACE_MAX_ACTIVE=16

# Working directory root for workspace storage
# Default: /app/data/rag_storage
# WORKING_DIR=/app/data/rag_storage

# Input directory root for workspace file uploads
# Default: /app/data/inputs
# INPUT_DIR=/app/data/inputs
