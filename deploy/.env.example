# Copy this file to .env (same directory as the compose file) and fill in.

# Domain this will be served on. Needs an A/AAAA record pointing at this
# host before you start the stack (Let's Encrypt needs to reach it).
DOMAIN=mcp.example.com

# Base URL of your EXISTING LightRAG instance, reachable from this
# compose stack. If LightRAG runs in its own compose project, either put
# this stack on the same docker network and use the container name
# (http://lightrag:9621), or use a URL reachable over the network/internet.
LIGHTRAG_URL=http://lightrag:9621

# LightRAG's own API key (X-API-Key) — whatever you already set for your
# LightRAG instance.
LIGHTRAG_API_KEY=

# Password for the one-time OAuth login screen shown in the browser when
# a new client (claude.ai, Claude Desktop, ...) first connects. Pick
# anything reasonably strong — mcp-auth-proxy hashes it internally, this
# is not used per-request afterward. Generate one:
#   openssl rand -hex 20
MCP_AUTH_PASSWORD=

# Optional: override the git ref installed from github.com/alexbic/lightrag-mcp-connect
# instead of the latest stable release pinned by default in this repo's
# own deploy files. Accepts a tag, branch (e.g. main), or commit SHA.
# MCP_GIT_REF=v1.0.0

# docker-compose.traefik.yml only: name of the external docker network
# your Traefik instance is attached to.
# TRAEFIK_NETWORK=traefik-network
